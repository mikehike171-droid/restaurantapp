# backend/.env
NODE_ENV=development
PORT=3001

# PostgreSQL Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_NAME=restaurant_db

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Frontend URL (for QR code generation)
FRONTEND_URL=http://localhost:3000
